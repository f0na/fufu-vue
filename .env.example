# Bangumi API 代理配置
# 生产环境由 Cloudflare Workers 处理，开发环境由 Vite proxy 处理
# 无需修改此配置

# 开发环境代理目标（仅用于本地开发）
VITE_BANGUMI_API_BASE=https://api.bgm.tv

GITHUB_TOKEN=xxx

DATA_SOURCE=api

# 图片上传专用 Token（需要 repo 或 public_repo 权限）
GITHUB_UPLOAD_TOKEN=xxx

# GitHub 仓库配置
GITHUB_IMAGE_OWNER=f0na
GITHUB_IMAGE_REPO=fufu-next
GITHUB_IMAGE_PATH=content/imgs
GITHUB_BRANCH=main

BAIDU_TRANSLATION_APP_ID=xxx
BAIDU_TRANSLATION_APP_KEY=xxx
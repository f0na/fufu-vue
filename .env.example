VITE_API_BASE_URL=

# GitHub 图床（管理页图片上传用）
# 获取方式：GitHub Settings → Developer settings → Personal access tokens → Fine-grained tokens
# 仓库权限：Contents → Read and write（仅选择图片仓库）
VITE_GITHUB_TOKEN=
VITE_GITHUB_IMAGE_OWNER=
VITE_GITHUB_IMAGE_REPO=
VITE_GITHUB_IMAGE_PATH=content/imgs
VITE_GITHUB_BRANCH=main

# 图片加速代理（可选）
# 设为 jsdelivr 则使用 jsDelivr CDN 加速 GitHub raw 图片（推荐，免费且国内速度快）
# 也可设为自定义代理前缀，如 https://你的代理域名/
# 不配置则直连 GitHub raw
# VITE_IMAGE_PROXY_BASE=jsdelivr

# Giscus 评论区配置
# 从 https://giscus.app 获取
VITE_GISCUS_REPO=f0na/fufu-vue
VITE_GISCUS_REPO_ID=R_kgDOSF1Eww
VITE_GISCUS_CATEGORY=Announcements
VITE_GISCUS_CATEGORY_ID=DIC_kwDOSF1Ew8C7HmC